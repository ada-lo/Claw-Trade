# Free API keys
# Groq: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_key_here

# Gemini: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_key_here

# HuggingFace: https://huggingface.co/settings/tokens
# Required permissions: "Make calls to Inference Providers" + read public gated repos
HF_TOKEN=hf_your_hf_token_here
HUGGINGFACE_HUB_TOKEN=hf_your_hf_token_here

# Alpaca paper trading: https://app.alpaca.markets/paper/dashboard/overview
# Use PAPER trading keys only - never live keys
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_API_SECRET=your_alpaca_secret_here

# Pipeline config
# EXECUTION_MODE: dry-run | paper | live (never set live without HSM)
EXECUTION_MODE=dry-run
# FORMAL_VERIFY_MODE: strict | js-fallback
FORMAL_VERIFY_MODE=strict
FORMAL_VERIFY_PYTHON=python
Z3_VERIFIER_URL=http://z3_verifier:5001

# Paths (relative to project root)
POLICY_PATH=./policies/financial-guardrails.json
AUDIT_LOG_PATH=./runtime/audit/armorclaw.audit.jsonl
NONCE_STORE_PATH=./runtime/state/nonces.json

# ArmorClaw crypto keys
# Generated by: npm run generate:keys
ARMORCLAW_ED25519_PRIVATE_KEY_PATH=./runtime/keys/armorclaw-private.pem
ARMORCLAW_ED25519_PUBLIC_KEY_PATH=./runtime/keys/armorclaw-public.pem
# Change this to a random string before any paper-mode usage
ARMORCLAW_AUDIT_HMAC_SECRET=change-this-to-a-random-string-min-32-chars

PORT=1933